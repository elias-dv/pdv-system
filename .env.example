# ============================================================
#  PDV System — Configuração de Ambiente
#  Copie este arquivo para .env e preencha com seus dados
# ============================================================

# --- INFORMAÇÕES DA LOJA ---
STORE_NAME="Meu Comércio"
STORE_CNPJ=""
STORE_ADDRESS=""
STORE_PHONE=""

# --- EMAIL (NODEMAILER) ---
# Provedor SMTP (gmail, outlook, yahoo, ou custom)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Conta de envio (quem envia)
EMAIL_USER=seu.email@gmail.com
# Para Gmail: use uma "Senha de App" (não a senha da conta)
# Gere em: myaccount.google.com/apppasswords
EMAIL_PASS=sua_senha_de_app_aqui

# Destinatário do relatório diário
EMAIL_TO=destinatario@gmail.com

# Nome exibido no remetente
EMAIL_FROM_NAME="PDV Sistema"

# --- BACKUP ---
# Pasta onde os backups serão salvos
# Padrão: pasta 'backups' dentro da pasta de dados do usuário
BACKUP_PATH=

# Quantidade máxima de backups para manter
BACKUP_MAX_FILES=30

# Horário do backup automático diário (formato HH:MM, 24h)
BACKUP_SCHEDULE_TIME=23:50
